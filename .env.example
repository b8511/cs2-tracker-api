# CORS — comma-separated list of allowed origins
# e.g. "https://new-cs-dashboard.vercel.app,http://localhost:5173"
ALLOWED_ORIGINS=http://localhost:5173

# Cloudflare R2 (optional — only needed for image fallback / seeding)
# Find your account ID at: https://dash.cloudflare.com → R2 Object Storage
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=cs2-images
R2_ACCESS_KEY=<R2_ACCESS_KEY_ID>
R2_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
